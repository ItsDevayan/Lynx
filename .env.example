# ─────────────────────────────────────────────────────────────────────────────
# Lynx — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Ports are chosen to NOT conflict with common dev tools:
#   (3000/3001 React, 4000 common API, 5432 system PG, 6379 system Redis)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Port Configuration ───────────────────────────────────────────────────────
# Override any of these to avoid conflicts with your running services.

LYNX_DASHBOARD_PORT=7137     # React SPA  → http://localhost:7137
LYNX_API_PORT=4747            # Fastify API → http://localhost:4747
LYNX_PG_PORT=5433             # PostgreSQL  (internal stays 5432)
LYNX_REDIS_PORT=6382          # Redis       (internal stays 6379)
LYNX_QDRANT_PORT=6340         # Qdrant HTTP (internal stays 6333)
LYNX_QDRANT_GRPC_PORT=6341    # Qdrant gRPC (internal stays 6334)

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=change-me-in-production-min-32-chars
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=lynx_dev
DATABASE_URL=postgresql://lynx:lynx_dev@localhost:5433/lynx
REDIS_URL=redis://localhost:6382
# REDIS_PASSWORD=              # Optional, leave blank for no Redis auth

# ─── Vector DB ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6340

# ─── Ollama (local, runs natively — NOT in Docker for GPU support) ─────────────
# Install: curl -fsSL https://ollama.com/install.sh | sh && ollama serve
OLLAMA_BASE_URL=http://localhost:11434
# Override model (Lynx auto-selects based on your bundle if not set):
# OLLAMA_MODEL=qwen2.5-coder:7b-instruct-q4_K_M

# ─── LLM Orchestrator API Keys ────────────────────────────────────────────────
# At least one recommended. Groq is free and uses Llama 3.3 70B.

# Groq — free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic Claude: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Notifications (optional) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=lynx@yourdomain.com
CUSTOM_WEBHOOK_URL=

# ─── Security Tools (auto-detected if in PATH) ────────────────────────────────
TRIVY_PATH=trivy
SEMGREP_PATH=semgrep
FALCO_WEBHOOK_PORT=2801

# ─── Kubernetes (optional) ────────────────────────────────────────────────────
KUBECONFIG=~/.kube/config
K8S_NAMESPACE=default

# ─── Scout / Intelligence ─────────────────────────────────────────────────────
GITHUB_TOKEN=
# HN, ProductHunt, npm stats all use free public APIs

# ─── SigNoz (full profile only) ───────────────────────────────────────────────
SIGNOZ_ENDPOINT=http://localhost:4317
ENABLE_SIGNOZ=false

# ─── Diagnostics ──────────────────────────────────────────────────────────────
DIAGNOSTICS_OPT_IN=false
