{
  "name": "@lynx/core",
  "version": "0.1.0",
  "description": "Lynx core — shared types, HITL middleware, event bus, notifier, fingerprinting",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --tsconfig tsconfig.json",
    "dev": "tsup src/index.ts --format esm --dts --watch --tsconfig tsconfig.json",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "nodemailer": "^6.9.16",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8",
    "source-map": "^0.7.4",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/pg": "^8.11.0",
    "@types/nodemailer": "^6.4.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.0.0"
  }
}
